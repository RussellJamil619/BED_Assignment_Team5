# Environment variables required for the backend to connect to SQL Server.
# Copy this file to a new file named ".env" (no .example) and fill in the values
# specific to your local SQL Server installation.

DB_USER=your_sql_username
DB_PASSWORD=your_sql_password
DB_SERVER=localhost
DB_DATABASE=HawkerCentreDB
PORT=3000

# Notes for setup:
# - DB_SERVER is typically "localhost" for a default instance
#   or "localhost\SQLEXPRESS" for a named Express instance.
# - Ensure the SQL Server Browser service is running if using a named instance.
# - Ensure TCP/IP is enabled in SQL Server Configuration Manager.
# - Ensure the login you specify has permission to connect and access HawkerCentreDB.